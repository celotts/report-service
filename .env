# ========== Spring Boot ==========
SPRING_PROFILES_ACTIVE=dev
SPRING_APPLICATION_NAME=ms-report
SERVER_PORT=7070

# ========== Config Server ==========
SPRING_CONFIG_IMPORT=optional:configserver:http://patient-config-service:8888
SPRING_CLOUD_CONFIG_URI=http://patient-config-service:8888

# ========== Git Config ==========
GIT_USERNAME=carloslott
GITHUB_TOKEN=ghp_xxx_tu_token_real
SPRING_CLOUD_CONFIG_SERVER_GIT_URI=https://github.com/carloslott/medical-config-repo
CONFIG_USER=configuser
CONFIG_USER_PASSWORD=a501082a-0573-4ff0-9522-d5c3d4b2e859

# ========== Eureka ==========
EUREKA_CLIENT_ENABLED=true
EUREKA_CLIENT_REGISTER_WITH_EUREKA=true
EUREKA_CLIENT_FETCH_REGISTRY=true
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://registry-service:8761/eureka/

# ========== Base de Datos ==========
POSTGRES_DB=patient_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_HOST=patient-db
DB_PORT=5432

SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${POSTGRES_DB}
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}